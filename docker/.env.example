# ============================================================
#  Plantilla de variables de entorno.
#
#  NO edites este archivo para trabajar: genera tu copia local con
#
#      node scripts/setup-env.js
#
#  Eso crea docker/.env con un JWT_SECRET aleatorio propio de tu maquina.
#  docker/.env NUNCA se sube al repositorio (esta en .gitignore).
# ============================================================

# --- PostgreSQL (contenedor db) ---
# Credenciales SOLO para la base de datos local en Docker. No son de produccion.
POSTGRES_USER=inupa_admin
POSTGRES_PASSWORD=inupa_local_dev
POSTGRES_DB=inupadb
# Puerto en tu maquina fisica (cambialo si tienes conflicto con un Postgres local)
HOST_DB_PORT=5432

# --- Backend ---
NODE_ENV=development
PORT=3000
DB_USER=inupa_admin
DB_PASSWORD=inupa_local_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inupadb

# URL de conexion para Prisma (manual y local)
DATABASE_URL="postgresql://inupa_admin:inupa_local_dev@localhost:5432/inupadb?schema=public"

# Secreto para firmar los JWT.
# El script de setup lo reemplaza por un valor aleatorio. NUNCA lo compartas.
JWT_SECRET=GENERAR_CON_EL_SCRIPT_DE_SETUP

# --- Correo (OPCIONAL) ---
# Solo hace falta si vas a probar el login por OTP (envio de codigos).
# Sin esto la app arranca igual; unicamente falla el envio del correo.
# Se usa una App Password de Gmail (no tu contrasena normal).
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=

# --- Google OAuth ---
# El Client ID es PUBLICO (viaja al navegador), no es un secreto.
# Solo hace falta si vas a probar el boton "Continuar con Google".
GOOGLE_CLIENT_ID=72476361188-5q85ahrv0i6j8bagr44p6n8m42dfaqgb.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=72476361188-5q85ahrv0i6j8bagr44p6n8m42dfaqgb.apps.googleusercontent.com
