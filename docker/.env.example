# ============================================================
#  Plantilla de variables de entorno para Docker Compose.
#  1) Copia este archivo a  docker/.env
#  2) Rellena los valores reales (pídelos al líder del proyecto).
#  NUNCA subas docker/.env al repositorio (está en .gitignore).
# ============================================================

# --- PostgreSQL (contenedor db) ---
POSTGRES_USER=inupa_admin
POSTGRES_PASSWORD=CAMBIA_ESTO
POSTGRES_DB=inupadb

# --- Backend ---
NODE_ENV=development
PORT=3000
DB_USER=inupa_admin
DB_PASSWORD=CAMBIA_ESTO
DB_HOST=db
DB_PORT=5432
DB_NAME=inupadb
JWT_SECRET=GENERA_UN_SECRETO_LARGO_Y_ALEATORIO
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu_correo@ejemplo.com
MAIL_PASS=tu_app_password
